# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# Vite loads `.env.local` automatically (see https://vitejs.dev/guide/env-and-mode.html).

# --- Firebase (client; Vite exposes only VITE_*)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- OpenAI (server: api/coach.js on Vercel; optional locally if you proxy coach)
OPENAI_API_KEY=

# --- Web Push (server only; used by /api/push/* and /api/cron/push)
# Prefer VAPID_PUBLIC_KEY. If Vercel only has NEXT_PUBLIC_VAPID_PUBLIC_KEY, the API reads that too.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
