# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# Vite loads `.env.local` automatically (see https://vitejs.dev/guide/env-and-mode.html).

# --- Firebase (client; Vite exposes only VITE_*)
# iOS native (@capacitor-firebase/authentication): register an iOS app in Firebase (bundle id app.proyou.proyou), download GoogleService-Info.plist, and replace ios/App/App/GoogleService-Info.plist so GOOGLE_APP_ID is the :ios:… id (and CLIENT_ID / REVERSED_CLIENT_ID appear after Google Sign-In is enabled). Until then, the committed plist satisfies FirebaseApp.configure() using your web app id where applicable.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Capacitor iOS/Android: set to your real https origin (e.g. Vercel URL) so Firebase Auth + /api/* resolve after Apple/Google redirects. Add the same host under Firebase Console → Authentication → Settings → Authorized domains.
# VITE_APP_ORIGIN=https://your-app.vercel.app

# Native iOS (Capacitor) Sign in with Apple → Firebase: bundle id or Apple Services ID (must match Apple Developer + Firebase “Apple” provider). Optional override for redirect URI (default: https://YOUR_AUTH_DOMAIN/__/auth/handler).
# VITE_APPLE_IOS_CLIENT_ID=app.proyou.proyou
# VITE_APPLE_SERVICE_ID=com.example.yourweb.service
# VITE_APPLE_REDIRECT_URI=https://your-project.firebaseapp.com/__/auth/handler

# --- OpenAI (server: api/coach.js on Vercel; optional locally if you proxy coach)
OPENAI_API_KEY=

# --- Web Push (server only; used by /api/push/* and /api/cron/push)
# Prefer VAPID_PUBLIC_KEY. If Vercel only has NEXT_PUBLIC_VAPID_PUBLIC_KEY, the API reads that too.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
