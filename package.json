{
  "name": "cute-schedule",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test:coach": "node --test api/lib/coachValidate.test.mjs",
    "preview": "vite preview",
    "trigger-deploy": "sh -c 'if [ -z \"$VERCEL_DEPLOY_HOOK_URL\" ]; then echo \"Set VERCEL_DEPLOY_HOOK_URL to your Vercel deploy hook (Dashboard → Project → Settings → Git → Deploy Hooks).\" >&2; exit 1; fi; curl -s -X POST \"$VERCEL_DEPLOY_HOOK_URL\"'",
    "cap:sync": "npm run build && npx cap sync && node scripts/merge-ios-cap-plugin-classes.mjs",
    "cap:sync:ios": "npm run build && npx cap sync ios && node scripts/merge-ios-cap-plugin-classes.mjs",
    "cap:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor-firebase/authentication": "^7.5.0",
    "@capacitor-firebase/messaging": "^7.5.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@capacitor/local-notifications": "^7.0.6",
    "@upstash/redis": "^1.36.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "^6.0.3",
    "vite": "^7.2.4"
  }
}
