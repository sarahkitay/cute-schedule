rules_version = '2';

// App writes to: schedules/{deviceId}
// Replace with auth-based rules before production (e.g. request.auth.uid == userId).
service cloud.firestore {
  match /databases/{database}/documents {
    match /schedules/{deviceId} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
