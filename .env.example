# Firebase (required for Firestore sync)
# Vite only exposes vars prefixed with VITE_ - on Vercel use exactly these names.
# Get values from Firebase Console → Project settings → Your apps (Web app).
#
# Authentication (Firebase Console → Authentication → Sign-in method):
# - Enable Anonymous (guest sessions get a real uid so Firestore rules can scope data).
# - Enable Google and/or Email/Password for accounts (Settings → Account & cloud sync in the app).
# - Capacitor / iOS WebView: Authentication → Settings → Authorized domains must include "localhost"
#   (Capacitor loads from https://localhost). Google sign-in also needs your iOS URL scheme configured for OAuth.
#
# Firestore rules must allow read/write on collection "schedules" (see firestore.rules).
# Rules with "allow read, write: if false" block all saves - nothing will persist to Firestore.
# Capacitor / iOS: set to your production site so `/api/*` calls reach Vercel (baked in at `vite build`).
# Example: https://proyou.vercel.app (no trailing slash)
VITE_APP_ORIGIN=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push / VAPID (Vercel server / API routes only - do NOT prefix with VITE_)
# Only needed for browser + PWA Web Push (PushManager + service worker). Not used for native iOS
# Native iOS App Store builds use Apple Push Notification service (APNs), e.g. via @capacitor/push-notifications.
# Generate: npx web-push generate-vapid-keys
# In Vercel → Project → Settings → Environment Variables (Production + Preview).
# If you named the public key NEXT_PUBLIC_VAPID_PUBLIC_KEY on Vercel, it still works server-side here.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for push services (mailto: or https: URL)
VAPID_SUBJECT=mailto:you@example.com

# AI coach (Vercel server /api/coach only - never VITE_)
OPENAI_API_KEY=

# Subscriptions + reminders are stored in Vercel KV (see @vercel/kv in api/push/*).
# Create KV in Vercel → Storage → KV and connect it to this project, or subscribe/save will 500.
#
# Cron path /api/cron/push uses vercel.json schedule (default every 5 minutes). If deploy rejects the
# cron expression on your plan, change vercel.json to e.g. "0 * * * *" (hourly).
