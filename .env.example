# Firebase (required for Firestore sync)
# Vite only exposes vars prefixed with VITE_ — on Vercel use exactly these names.
# Get values from Firebase Console → Project settings → Your apps (Web app).
#
# Firestore rules must allow read/write on collection "schedules" (see firestore.rules).
# Rules with "allow read, write: if false" block all saves — nothing will persist to Firestore.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
