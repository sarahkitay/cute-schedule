# Firebase (required for Firestore sync)
# Vite only exposes vars prefixed with VITE_ - on Vercel use exactly these names.
# Get values from Firebase Console → Project settings → Your apps (Web app).
#
# Authentication (Firebase Console → Authentication → Sign-in method):
# - Enable Anonymous (guest sessions get a real uid so Firestore rules can scope data).
# - Enable Google and/or Email/Password for accounts (Settings → Account & cloud sync in the app).
# - Capacitor / iOS WebView: Authentication → Settings → Authorized domains must include "localhost"
#   (Capacitor loads from https://localhost). Google sign-in also needs your iOS URL scheme configured for OAuth.
#
# Firestore rules must allow read/write on collection "schedules" (see firestore.rules).
# Rules with "allow read, write: if false" block all saves - nothing will persist to Firestore.
# Capacitor / iOS: set to your production site so `/api/*` calls reach Vercel (baked in at `vite build`).
# Example: https://proyou.vercel.app (no trailing slash)
VITE_APP_ORIGIN=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push / VAPID (Vercel server / API routes only - do NOT prefix with VITE_)
# Only needed for browser + PWA Web Push (PushManager + service worker). Not used for native iOS
# Native iOS App Store builds use Apple Push Notification service (APNs), e.g. via @capacitor/push-notifications.
# Generate: npx web-push generate-vapid-keys
# In Vercel → Project → Settings → Environment Variables (Production + Preview).
# If you named the public key NEXT_PUBLIC_VAPID_PUBLIC_KEY on Vercel, it still works server-side here.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for push services (mailto: or https: URL)
VAPID_SUBJECT=mailto:you@example.com

# AI coach (Vercel server /api/coach only - never VITE_)
OPENAI_API_KEY=
# Coach rate limit (uses same Upstash Redis as push). Defaults: 10 requests / 60s per client IP.
# COACH_RATE_LIMIT_MAX=10
# COACH_RATE_LIMIT_WINDOW_SEC=60

# Optional: comma-separated exact origins for CORS on /api/coach and /api/push/* (omit or "*" = allow any).
# Capacitor iOS uses Origin: https://localhost — the server always reflects that origin when API_ALLOWED_ORIGINS is set (see api/lib/cors.js), so you can still lock web origins to your Vercel URL.
# Example: https://your-app.vercel.app
API_ALLOWED_ORIGINS=

# When set, Vercel Cron invokes /api/cron/push with Authorization: Bearer <CRON_SECRET>.
# Generate: openssl rand -hex 32
CRON_SECRET=

# Local only: Vercel Dashboard → Project → Settings → Git → Deploy Hooks (do not commit the URL).
# npm run trigger-deploy
VERCEL_DEPLOY_HOOK_URL=

# --- Native iOS push (APNs HTTP/2 on Vercel; server-only, never VITE_)
# Apple: Keys → create APNs key (.p8). Team ID and Key ID from Apple Developer.
# Paste the full .p8 PEM in one line with literal \n for newlines, OR use a single-line secret store.
# IOS_BUNDLE_ID must match the Xcode target (e.g. app.proyou.proyou).
# For Xcode installs / TestFlight debug builds use APNS_PRODUCTION=false; App Store device tokens need true.
APNS_PRIVATE_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
IOS_BUNDLE_ID=app.proyou.proyou
APNS_PRODUCTION=false

# Optional: verify Firebase ID tokens on /api/push/register-native and /api/push/reminders-native (JSON string of service account).
# Firebase Console → Project settings → Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Subscriptions + reminders use Upstash Redis (@upstash/redis, api/lib/redisClient.js).
# Vercel: Storage → Redis (Upstash) → link project, then `vercel env pull .env.development.local`.
# Required env (filled automatically when you link Redis on Vercel):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#
# Cron path /api/cron/push uses vercel.json (e.g. daily at 18:00 UTC). Adjust schedule in vercel.json if needed.
